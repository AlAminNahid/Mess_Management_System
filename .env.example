NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=replace-with-db-username
DB_PASSWORD=replace-with-db-password
DB_DATABASE=mess_management_system
# Max Postgres connections this instance's pool will open.
# If running multiple instances behind a load balancer, keep
# (DB_POOL_MAX * instance count) comfortably under Postgres's max_connections.
DB_POOL_MAX=10
DB_SSL=false

CORS_ORIGIN=http://localhost:4000

JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

MESS_PASSWORD_ENCRYPTION_KEY=replace-with-a-32-byte-hex-string
